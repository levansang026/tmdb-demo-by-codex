// Shared.xcconfig
// Minimal shared configuration for scaffold tool customization
// All other settings use Xcode project defaults
// Generated by XcodeBuildMCP

#include? "Secrets.xcconfig"

// ==========================================
// Project Identity
// ==========================================
PRODUCT_NAME = TMDBNetflix
PRODUCT_DISPLAY_NAME = TMDB Netflix
PRODUCT_BUNDLE_IDENTIFIER = com.billle.tmdbnetflix
MARKETING_VERSION = 1.0
CURRENT_PROJECT_VERSION = 1

// ==========================================
// Platform Configuration
// ==========================================
IPHONEOS_DEPLOYMENT_TARGET = 26.0
SWIFT_VERSION = 6.0
SWIFT_STRICT_CONCURRENCY = complete

// (1 == iPhone, 2 == iPad)
TARGETED_DEVICE_FAMILY = 1,2

// ==========================================
// Info PLIST
// ==========================================
GENERATE_INFOPLIST_FILE = YES
INFOPLIST_KEY_UISupportedInterfaceOrientations = portrait landscape-left landscape-right
INFOPLIST_KEY_UISupportedInterfaceOrientations_iPad = portrait portrait-upside-down landscape-left landscape-right
TMDB_API_KEY =
INFOPLIST_KEY_TMDBAPIKey = $(TMDB_API_KEY)

// ==========================================
// Entitlements
// ==========================================
// AI agents can modify Config/TMDBNetflix.entitlements to add capabilities
CODE_SIGN_ENTITLEMENTS = Config/TMDBNetflix.entitlements
